{
  "paths": {
    "internal_metadata_csv": "/path/to/internal_metadata.csv",
    "external_metadata_csv": "/path/to/external_metadata.csv",
    "preprocessed_root": "/path/to/preprocessed_outputs",
    "radiomics_output_root": "/path/to/preprocessed_outputs/radiomics_raw",
    "selected_features_root": "/path/to/preprocessed_outputs/radiomics_selected",
    "model_selection_output_dir": "/path/to/preprocessed_outputs/model_selection",
    "final_output_dir": "/path/to/preprocessed_outputs/final_training",
    "images": {
      "development_dir": "/path/to/development/images",
      "internal_test_dir": "/path/to/internal_test/images",
      "external_test_dir": "/path/to/external_test/images"
    },
    "masks": {
      "development_dir": "/path/to/development/masks",
      "internal_test_dir": "/path/to/internal_test/masks",
      "external_test_dir": "/path/to/external_test/masks"
    },
    "radiomics": {
      "development_raw_csv": "/path/to/preprocessed_outputs/radiomics_raw/development_raw.csv",
      "internal_test_raw_csv": "/path/to/preprocessed_outputs/radiomics_raw/internal_test_raw.csv",
      "external_test_raw_csv": "/path/to/preprocessed_outputs/radiomics_raw/external_test_raw.csv"
    },
    "final_selected_radiomics": {
      "development_csv": "/path/to/preprocessed_outputs/radiomics_selected/final/development_selected.csv",
      "internal_test_csv": "/path/to/preprocessed_outputs/radiomics_selected/final/internal_test_selected.csv",
      "external_test_csv": "/path/to/preprocessed_outputs/radiomics_selected/final/external_test_selected.csv"
    }
  },
  "columns": {
    "sample_id": "ID",
    "patient_id": "patient_id",
    "label": "label",
    "group": "group",
    "external_patient_id": "patient_id"
  },
  "dataset_roles": {
    "development_group_value": "train",
    "internal_test_group_value": "test",
    "external_test_role_name": "external_test"
  },
  "dataset": {
    "allowed_image_suffixes": [
      ".nii.gz",
      ".nii",
      ".nii(1).gz"
    ]
  },
  "cross_validation": {
    "n_splits": 5,
    "seed": 2026
  },
  "feature_selection": {
    "top_k": 80,
    "min_auc": 0.6,
    "corr_threshold": 0.9
  },
  "preprocessing": {
    "image": {
      "roi_size": [
        32,
        64,
        64
      ],
      "intensity_window": [
        -160.0,
        240.0
      ],
      "augmentation": {
        "enable_random_flip": true,
        "flip_probability": 0.5,
        "enable_random_rotate90": true,
        "rotate90_probability": 0.5,
        "enable_random_affine": true,
        "affine_probability": 0.3,
        "rotate_range": [
          0.2,
          0.2,
          0.2
        ],
        "scale_range": [
          0.1,
          0.1,
          0.1
        ]
      }
    }
  },
  "runtime": {
    "batch_size": 16,
    "eval_batch_size": 16,
    "num_workers": 4,
    "pin_memory": true,
    "use_cache_dataset": true,
    "cache_rate": 1.0
  },
  "model": {
    "image_in_channels": 2,
    "mamba_embed_dim": 128,
    "mamba_d_state": 16,
    "mamba_d_conv": 4,
    "mamba_expand": 2,
    "radiomics_hidden_dim": 64,
    "fusion_hidden_dim": 64,
    "num_classes": 2,
    "dropout_rate": 0.4,
    "use_auxiliary_image_head": true
  },
  "training": {
    "max_epochs": 220,
    "model_selection_metric": "auc",
    "positive_class_index": 1,
    "max_grad_norm": 10.0,
    "label_smoothing": 0.05,
    "optimizer": {
      "name": "adam",
      "learning_rate": 5e-05,
      "weight_decay": 0.0001
    },
    "scheduler": {
      "name": "cosine"
    },
    "auxiliary_loss": {
      "enable": true,
      "image_weight": 0.1,
      "radiomics_weight": 0.05
    },
    "fixed_threshold": 0.5
  }
}
